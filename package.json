{
  "name": "flowframe-v2",
  "version": "0.1.0",
  "private": true,
  "description": "FlowFrame V2 cross-platform AI workflow product MVP.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace @flowframe/web run dev",
    "build:web": "npm --workspace @flowframe/web run build",
    "typecheck": "tsc -b packages/core apps/web apps/android",
    "dev:android": "npm --workspace @flowframe/android run start"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
